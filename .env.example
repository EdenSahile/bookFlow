# Base de données Supabase — copie ce fichier en .env et remplis les valeurs
DATABASE_URL="postgresql://postgres:[TON-MOT-DE-PASSE]@[TON-HOST].supabase.co:5432/postgres"

# NextAuth — génère une clé aléatoire : openssl rand -base64 32
NEXTAUTH_SECRET="remplace-par-une-cle-secrete-longue-et-aleatoire"
NEXTAUTH_URL="http://localhost:3000"

# En production sur Vercel, NEXTAUTH_URL = ton URL Vercel
